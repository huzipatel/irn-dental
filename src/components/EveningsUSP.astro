---
---

<section id="evenings" class="bg-royal text-paper border-b-4 border-ink">
  <div class="mx-auto max-w-7xl px-5 sm:px-8 py-24 md:py-32 grid md:grid-cols-12 gap-12 items-start">

    <div class="md:col-span-7">
      <p class="eyebrow eyebrow-ink" style="color: #ffd500">§ 03 · Late nights</p>
      <h2 class="display-lg mt-4">
        Open till eight,<br/><span class="text-sun">four nights a week.</span>
      </h2>
      <p class="mt-8 max-w-xl text-paper/90 text-[17px] leading-[1.6]">
        Most dentists shut when your work shuts. That's daft. We hold reservations
        until 20:00 Mon–Thu so you can come after your shift, see us, and be home
        before EastEnders.
      </p>

      <a
        href="#contact"
        class="mt-10 inline-flex items-center gap-2 bg-irn text-ink font-display uppercase tracking-[0.15em] text-[15px] px-7 py-4 border-2 border-paper hover:bg-sun transition-colors"
      >
        Grab a late slot →
      </a>
    </div>

    <!-- Right: massive 20:00 display, can-style -->
    <aside class="md:col-span-5 bg-paper text-ink border-4 border-ink p-6 relative">
      <p class="eyebrow">Last reservation</p>
      <p class="font-display text-[160px] leading-[0.85] text-irn tnum mt-2">20:00</p>
      <p class="font-display uppercase tracking-[0.15em] text-[14px] mt-1">Monday — Thursday</p>

      <div class="mt-8 border-t-2 border-ink pt-5 grid grid-cols-3 gap-3 text-[12px]">
        <div>
          <p class="text-fog uppercase tracking-[0.15em]">Fri</p>
          <p class="font-display text-[18px] tnum">18:00</p>
        </div>
        <div>
          <p class="text-fog uppercase tracking-[0.15em]">Sat</p>
          <p class="font-display text-[18px] tnum">16:00</p>
        </div>
        <div>
          <p class="text-fog uppercase tracking-[0.15em]">Sun</p>
          <p class="font-display text-[18px] tnum">Emerg.</p>
        </div>
      </div>
    </aside>
  </div>
</section>
