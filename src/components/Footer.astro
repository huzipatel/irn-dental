---
import Mark from "./Mark.astro";
const year = new Date().getFullYear();
---

<footer class="bg-irn text-ink border-t-4 border-ink">
  <div class="mx-auto max-w-7xl px-5 sm:px-8 py-14 grid md:grid-cols-12 gap-10">

    <div class="md:col-span-5">
      <a href="#" class="flex items-center gap-3" aria-label="IRN Dental home">
        <Mark size={48} class="text-ink" />
        <span class="flex flex-col leading-none">
          <span class="font-display uppercase text-[24px] tracking-tight">IRN Dental</span>
          <span class="text-[10px] uppercase tracking-[0.3em] mt-1 text-ink/70">Made in Lancashire from teeth</span>
        </span>
      </a>
      <p class="mt-6 max-w-sm text-[14px] leading-[1.65] text-ink/85">
        Blackburn's other national smile. Open late four nights a week. Family,
        cosmetic, emergency. Phenomenal.
      </p>
    </div>

    <div class="md:col-span-3">
      <p class="eyebrow eyebrow-ink">Reach us</p>
      <ul class="mt-3 space-y-1.5 text-[14px] font-medium">
        <li><a href="tel:+440000000000" class="hover:underline">0000 000 0000</a></li>
        <li><a href="mailto:hello@irn.dental" class="hover:underline">hello@irn.dental</a></li>
        <li class="text-ink/80 mt-3">Blackburn · Lancashire</li>
      </ul>
    </div>

    <div class="md:col-span-4">
      <p class="eyebrow eyebrow-ink">Hours</p>
      <ul class="mt-3 space-y-1 text-[14px] tnum font-medium">
        <li>Mon — Thu &nbsp; 08:00 — 20:00</li>
        <li>Friday &nbsp; 08:00 — 18:00</li>
        <li>Saturday &nbsp; 09:00 — 16:00</li>
        <li>Sunday &nbsp; emergencies only</li>
      </ul>
    </div>
  </div>

  <div class="border-t-2 border-ink">
    <div class="mx-auto max-w-7xl px-5 sm:px-8 py-5 flex flex-wrap items-center justify-between gap-3 text-[11px] font-display uppercase tracking-[0.25em] text-ink/80">
      <span>© {year} IRN Dental · No. 1901</span>
      <span>Regulated by GDC · CQC</span>
      <span>Independent · Not affiliated with AG Barr</span>
    </div>
  </div>
</footer>
