---
const hours = [
  { day: "Monday",    times: "08:00 — 20:00", tag: "Late" },
  { day: "Tuesday",   times: "08:00 — 20:00", tag: "Late" },
  { day: "Wednesday", times: "08:00 — 20:00", tag: "Late" },
  { day: "Thursday",  times: "08:00 — 20:00", tag: "Late" },
  { day: "Friday",    times: "08:00 — 18:00", tag: "" },
  { day: "Saturday",  times: "09:00 — 16:00", tag: "" },
  { day: "Sunday",    times: "Emergencies only", tag: "Emergency" },
];
---

<section id="hours" class="bg-paper border-b-4 border-ink">
  <div class="mx-auto max-w-7xl px-5 sm:px-8 py-24 md:py-32 grid md:grid-cols-12 gap-12 items-start">

    <div class="md:col-span-5">
      <p class="eyebrow">§ 05 · Hours</p>
      <h2 class="display-lg mt-4">
        When we're<br/><span class="text-irn">switched on.</span>
      </h2>
      <p class="mt-8 max-w-md text-ink/80 text-[16px] leading-[1.7]">
        Late four nights, a half-day Saturday, Sunday on call for emergencies only.
        Walk-ins handled when we can. Booked in is always better.
      </p>
    </div>

    <div class="md:col-span-7">
      <ul class="border-t-2 border-ink">
        {hours.map(h => (
          <li class="grid grid-cols-[1fr,auto,80px] items-center gap-4 py-4 border-b-2 border-ink">
            <span class="font-display uppercase text-[22px] tracking-tight">{h.day}</span>
            <span class="font-display text-[20px] tnum text-ink/80">{h.times}</span>
            <span class="text-right">
              {h.tag && (
                <span class={`font-display uppercase tracking-[0.15em] text-[11px] px-2 py-1 ${h.tag === "Late" ? "bg-irn text-paper" : "bg-ink text-irn"}`}>{h.tag}</span>
              )}
            </span>
          </li>
        ))}
      </ul>
    </div>
  </div>
</section>
