---
interface Props { size?: number; class?: string }
const { size = 64, class: cls = "" } = Astro.props;
---
<!-- IRN Dental mark: bold roundel, "IRN" stacked over "DENTAL", girder cross. -->
<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 64 64"
     width={size} height={size} class={cls} aria-hidden="true">
  <circle cx="32" cy="32" r="30" fill="currentColor" />
  <!-- Girder X (Made in Scotland from girders nod) -->
  <g stroke="#ffffff" stroke-width="2.4" fill="none" stroke-linecap="square">
    <path d="M14 14 L50 50" />
    <path d="M50 14 L14 50" />
  </g>
  <!-- centre badge -->
  <circle cx="32" cy="32" r="13" fill="#ffffff" />
  <text x="32" y="30" text-anchor="middle"
        font-family="Anton, 'Arial Narrow', sans-serif"
        font-size="11" font-weight="700" fill="currentColor"
        letter-spacing="0.5">IRN</text>
  <text x="32" y="40" text-anchor="middle"
        font-family="Anton, 'Arial Narrow', sans-serif"
        font-size="6" font-weight="700" fill="currentColor"
        letter-spacing="1.2">DENTAL</text>
</svg>
