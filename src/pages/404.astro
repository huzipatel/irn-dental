---
import Base from "../layouts/Base.astro";
import Mark from "../components/Mark.astro";
---
<Base title="Lost · IRN Dental" description="Page not found.">
  <main class="min-h-screen flex items-center justify-center bg-irn text-paper px-6 text-center">
    <div>
      <Mark size={96} class="text-ink mx-auto" />
      <p class="eyebrow eyebrow-ink mt-8">Error · 404</p>
      <h1 class="display-lg mt-4">Couldnae find that page.</h1>
      <p class="mt-6 text-paper/90">Probably moved. Probably our fault.</p>
      <a href="/" class="mt-10 inline-flex items-center gap-2 bg-ink text-paper font-display uppercase tracking-[0.15em] text-[14px] px-6 py-3 border-2 border-ink hover:bg-paper hover:text-ink transition-colors">
        Back to the front →
      </a>
    </div>
  </main>
</Base>
